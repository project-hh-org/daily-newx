{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal",
      "node": "24.13.1",
      "ios": { "simulator": true, "image": "latest" },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://daily-newx.vercel.app",
        "EXPO_PUBLIC_USE_FIXTURE": "0"
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "node": "24.13.1",
      "ios": { "image": "latest" },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://daily-newx.vercel.app",
        "EXPO_PUBLIC_USE_FIXTURE": "0"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "node": "24.13.1",
      "ios": { "image": "latest" },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://daily-newx.vercel.app",
        "EXPO_PUBLIC_USE_FIXTURE": "0"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6781994189"
      }
    }
  }
}
