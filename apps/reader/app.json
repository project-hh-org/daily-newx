{
  "expo": {
    "name": "daily-newx",
    "slug": "daily-newx-reader",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "dailynewx",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": ["expo-router"]
  }
}
