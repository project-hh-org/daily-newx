# Supabase (서버 전용 — 절대 커밋 금지, .env.local 에 실제값)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 인제스트 API 인증 토큰 (루틴/어드민이 POST 시 Bearer 로 사용)
INGEST_TOKEN=YOUR_LONG_RANDOM_TOKEN

# (선택, 로컬 전용) 공개 GET 에서 draft 도 보이게. 프로덕션엔 절대 두지 말 것.
PUBLIC_READ_DRAFTS=1

# 루틴(daily-llm-news)이 POST 할 대상.
# 로컬: http://localhost:4000/api/daily-news
# https://daily-newx.vercel.app/api/daily-news
INGEST_URL=https://daily-newx.vercel.app/api/daily-news
