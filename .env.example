# Supabase (서버 전용 — 절대 커밋 금지, .env.local 에 실제값)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 인제스트 API 인증 토큰 (루틴/어드민이 POST 시 Bearer 로 사용)
INGEST_TOKEN=YOUR_LONG_RANDOM_TOKEN

# 루틴(daily-llm-news)이 POST 할 대상. 로컬: http://localhost:3000/api/daily-news
INGEST_URL=http://localhost:3000/api/daily-news
