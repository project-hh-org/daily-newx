{
  "name": "daily-newx",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "yarn workspace daily-news-api dev",
    "build:api": "yarn workspace daily-news-api build",
    "test:api": "yarn workspace daily-news-api test",
    "typecheck:api": "yarn workspace daily-news-api typecheck",
    "reader": "yarn workspace reader start -c",
    "reader:web": "yarn workspace reader web -c",
    "reader:ios": "yarn workspace reader ios -c",
    "typecheck:reader": "yarn workspace reader typecheck",
    "typecheck": "yarn typecheck:api && yarn typecheck:reader",
    "ship": "bash scripts/ship.sh"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2"
  }
}
